# ============================================================================
# Environment Variables Configuration Template
# ============================================================================
# 
# This is a template file showing what environment variables are needed.
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env (not committed to git)
#    cp .env.example .env
# 2. Replace the placeholder below with your actual OpenAI API key
# 3. Get your API key at: https://platform.openai.com/account/api-keys
#
# SECURITY NOTES:
# - Never commit your actual .env file (it's in .gitignore)
# - Never share your API key in chat, email, or commits
# - Each team member needs their own API key
# - Keep the API key on a single line with no line breaks
#
# ============================================================================

# OpenAI API Key for cloud-based AI model access
# Replace the placeholder below with your actual key
OPENAI_API_KEY=your-openai-api-key-here

# Optional: JIRA API credentials used by ai-commit.js when -t/--ticket is provided
# Example:
# JIRA_BASE_URL=https://your-company.atlassian.net
# JIRA_EMAIL=api-user@company.com
# JIRA_API_TOKEN=your-jira-api-token
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
